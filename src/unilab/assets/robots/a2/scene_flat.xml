<mujoco model="a2 scene">
  <include file="a2.xml"/>

  <statistic center="0 0 0.1" extent="0.9" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <!-- priority=2 (> the feet's 1) + condim=6 makes the floor the priority geom
         for foot-ground contact, so it dictates the friction (and keeps condim 6).
         This lets ground-friction domain randomization actually move the contact
         friction; otherwise the priority-1 feet would override the floor. -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" priority="2" condim="6"/>
  </worldbody>

  <sensor>
    <contact name="FL_foot_contact" geom1="floor" geom2="FL" data="found" num="1" reduce="mindist"/>
    <contact name="FR_foot_contact" geom1="floor" geom2="FR" data="found" num="1" reduce="mindist"/>
    <contact name="RL_foot_contact" geom1="floor" geom2="RL" data="found" num="1" reduce="mindist"/>
    <contact name="RR_foot_contact" geom1="floor" geom2="RR" data="found" num="1" reduce="mindist"/>

    <contact name="base1_contact" geom1="floor" geom2="base1" data="found" num="1" reduce="mindist"/>
    <contact name="base2_contact" geom1="floor" geom2="base2" data="found" num="1" reduce="mindist"/>
    <contact name="base3_contact" geom1="floor" geom2="base3" data="found" num="1" reduce="mindist"/>

    <contact name="FL_thigh_contact" geom1="floor" geom2="fl_thigh_0" data="found" num="1" reduce="mindist"/>
    <contact name="FR_thigh_contact" geom1="floor" geom2="fr_thigh_0" data="found" num="1" reduce="mindist"/>
    <contact name="RL_thigh_contact" geom1="floor" geom2="rl_thigh_0" data="found" num="1" reduce="mindist"/>
    <contact name="RR_thigh_contact" geom1="floor" geom2="rr_thigh_0" data="found" num="1" reduce="mindist"/>

    <contact name="FL_calf_contact1" geom1="floor" geom2="fl_calf_0" data="found" num="1" reduce="mindist"/>
    <contact name="FR_calf_contact1" geom1="floor" geom2="fr_calf_0" data="found" num="1" reduce="mindist"/>
    <contact name="RL_calf_contact1" geom1="floor" geom2="rl_calf_0" data="found" num="1" reduce="mindist"/>
    <contact name="RR_calf_contact1" geom1="floor" geom2="rr_calf_0" data="found" num="1" reduce="mindist"/>

    <contact name="FL_calf_contact2" geom1="floor" geom2="fl_calf_1" data="found" num="1" reduce="mindist"/>
    <contact name="FR_calf_contact2" geom1="floor" geom2="fr_calf_1" data="found" num="1" reduce="mindist"/>
    <contact name="RL_calf_contact2" geom1="floor" geom2="rl_calf_1" data="found" num="1" reduce="mindist"/>
    <contact name="RR_calf_contact2" geom1="floor" geom2="rr_calf_1" data="found" num="1" reduce="mindist"/>
  </sensor>

  <!-- Home: A2 stand. qpos = base(7) + 12 leg (FL,FR,RL,RR x hip,thigh,calf).
       Aligned to the official unitree_rl_mjlab A2 INIT_STATE: spawn height 0.4,
       symmetric thigh 0.9 / calf -1.8 on all legs, left-hip -0.1 / right-hip
       +0.1. ctrl = the 12 leg targets (position actuators hold this pose at
       reset). -->
  <keyframe>
    <key name="home"
      qpos="0 0 0.4 1 0 0 0  -0.1 0.9 -1.8  0.1 0.9 -1.8  -0.1 0.9 -1.8  0.1 0.9 -1.8"
      ctrl="-0.1 0.9 -1.8  0.1 0.9 -1.8  -0.1 0.9 -1.8  0.1 0.9 -1.8"/>
  </keyframe>
</mujoco>
