    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="135" elevation="-25"/>
  </visual>
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.20 0.32 0.48"
             rgb2="0.04 0.07 0.12" width="512" height="3072"/>
    <texture type="2d" name="rotation_ground_tex" builtin="checker" mark="edge"
